{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "kui-realtime",
  "main": "src/index.js",
  "compatibility_date": "2026-07-12",
  "workers_dev": true,
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "kui",
      "database_id": "c01997bc-a226-4a27-82ef-d3c55c0667e3"
    }
  ],
  "durable_objects": {
    "bindings": [
      { "name": "VPS_PRESENCE", "class_name": "VpsPresence" },
      { "name": "DASHBOARD_HUB", "class_name": "DashboardHub" }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["VpsPresence", "DashboardHub"]
    }
  ],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 0.1
  }
}
